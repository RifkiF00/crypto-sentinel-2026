modules = ["python-3.10"]

[nix]
channel = "stable-23.11"

[workflows]
runButton = "Run"

[[workflows.workflow.tasks]]
isMainTask = true
lines = ["python -m uvicorn app.main:app --host 0.0.0.0 --port 8000"]

[deployment]
run = ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
